# Copy to .env and fill in your keys (never commit .env to git)
#   cp .env.example .env

# --- Azure Speech Translation (primary provider) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=canadacentral

# --- Azure Translator (backup provider #2 translation) ---
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=canadacentral

# --- Deepgram (backup provider STT, register at console.deepgram.com) ---
DEEPGRAM_API_KEY=

# Optional: set to 1 if you confirmed Deepgram auto-reload is OFF
DEEPGRAM_AUTOLOAD_DISABLED=1
