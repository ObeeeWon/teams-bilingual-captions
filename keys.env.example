# 新用户：复制本文件为 keys.env 并填入你自己的 Azure Key
#   cp keys.env.example keys.env
#
# ⚠️ 不要共用朋友的 Key！每人需独立 Azure 免费账号。
# 申请步骤见 docs/GETTING_STARTED.zh.md

# --- 必填：Azure Speech（主方案，每月 5 小时免费）---
# 创建: https://portal.azure.com/#create/Microsoft.CognitiveServicesSpeechServices
# 选 Pricing tier = Free F0，复制 Keys and Endpoint 页面内容
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=canadacentral

# --- 可选：Azure Translator（备用翻译，每月 200 万字符免费）---
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=canadacentral

# --- 可选：Deepgram（备用 STT，注册送 $200 赠金）---
# https://console.deepgram.com/signup
DEEPGRAM_API_KEY=

DEEPGRAM_AUTOLOAD_DISABLED=1
