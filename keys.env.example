# 申请链接（详见 docs/FREE_API_LINKS.zh.md）
# Azure 注册:     https://azure.microsoft.com/free/
# Speech 创建 F0: https://portal.azure.com/#create/Microsoft.CognitiveServicesSpeechServices
# Translator 可选: https://portal.azure.com/#create/Microsoft.CognitiveServicesTextTranslation
# Deepgram 可选:  https://console.deepgram.com/signup
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=canadacentral

# --- 可选：Azure Translator（备用翻译，每月 200 万字符免费）---
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=canadacentral

# --- 可选：Deepgram（备用 STT，注册送 $200 赠金）---
# https://console.deepgram.com/signup
DEEPGRAM_API_KEY=

DEEPGRAM_AUTOLOAD_DISABLED=1
