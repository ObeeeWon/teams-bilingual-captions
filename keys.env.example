# API keys — copy to keys.env on each machine (keys.env is NOT committed to git)
#   cp keys.env.example keys.env
# Then paste your Azure / Deepgram keys.

# --- Azure Speech (primary) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=canadacentral

# --- Azure Translator (backup translation, optional) ---
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=canadacentral

# --- Deepgram (backup STT, optional) ---
DEEPGRAM_API_KEY=

DEEPGRAM_AUTOLOAD_DISABLED=1
